{
  "name": "@nuewframe/nfauth",
  "version": "2.0.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-env --allow-net --allow-read --allow-write --allow-run main.ts",
    "test": "deno test --allow-env --allow-net --allow-read --allow-write --allow-run",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno task fmt:check && deno task lint && deno task test",
    "build:current": "deno compile --allow-env --allow-net --allow-read --allow-write --allow-run --vendor --output dist/nfauth main.ts",
    "build:macos-x64": "deno compile --allow-env --allow-net --allow-read --allow-write --allow-run --target x86_64-apple-darwin --vendor --output dist/nfauth-macos-x64 main.ts",
    "build:macos-arm64": "deno compile --allow-env --allow-net --allow-read --allow-write --allow-run --target aarch64-apple-darwin --vendor --output dist/nfauth-macos-arm64 main.ts",
    "build:linux-x64": "deno compile --allow-env --allow-net --allow-read --allow-write --allow-run --target x86_64-unknown-linux-gnu --vendor --output dist/nfauth-linux-x64 main.ts",
    "build:windows-x64": "deno compile --allow-env --allow-net --allow-read --allow-write --allow-run --target x86_64-pc-windows-msvc --vendor --output dist/nfauth-windows-x64.exe main.ts",
    "build:all": "deno task build:macos-x64 && deno task build:macos-arm64 && deno task build:linux-x64 && deno task build:windows-x64",
    "hooks": "deno run --allow-run --allow-read --allow-write scripts/install-hooks.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "@okta/okta-auth-js": "npm:@okta/okta-auth-js@^8.0.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2022",
      "DOM",
      "deno.ns"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  }
}
